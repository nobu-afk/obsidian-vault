$close_divs = preg_match_all('/<\/div>/i', $report_body);
$missing = $open_divs - $close_divs;
if ($missing > 0) {
    $report_body .= str_repeat('</div>', $missing);
} elseif ($missing < 0) {
    // 閉じタグが多すぎる場合は末尾から削除
    for ($i = 0; $i < abs($missing); $i++) {
        $report_body = preg_replace('/<\/div>\s*$/i', '', $report_body);
