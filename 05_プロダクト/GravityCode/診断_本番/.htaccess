# CODE diagnose 内部リソース保護
# 将来 SYSTEM プロンプト外出し時の予防保護
<FilesMatch "\.(txt|json|md|bak)$">
    Require all denied
</FilesMatch>

# generate_backup_*.php もロールバック専用・直接アクセス不可
<FilesMatch "^generate_backup_.*\.php$">
    Require all denied
</FilesMatch>

# generate_v2.php は本番置換後の旧名残骸・重複 API 防止のため deny
<FilesMatch "^generate_v2\.php$">
    Require all denied
</FilesMatch>
