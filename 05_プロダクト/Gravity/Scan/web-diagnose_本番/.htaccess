# Gravity 無料 Web 診断 — 内部リソース保護（260515 8 ページピボットで新パス）
# 配置先（FTP）: growthfix.jp/public_html/gravity/diagnose/.htaccess

# logs/ ディレクトリは完全アクセス禁止（CSV は内部運用のみ）
RedirectMatch 403 ^/gravity/diagnose/logs(/|$)

# .md / .txt / .bak / .sql / .log は直接アクセス禁止
<FilesMatch "\.(md|txt|bak|sql|log)$">
    Require all denied
</FilesMatch>

# .htaccess 自身の保護
<Files ".htaccess">
    Require all denied
</Files>

# index.html / generate.php は通常公開
DirectoryIndex index.html
